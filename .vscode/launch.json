{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "name": "Debug with readline-sync",
            "request": "launch",
            "program": "${workspaceFolder}/app.js", // change to your entry file
            "console": "integratedTerminal",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "command": "npm start",
            "name": "Run npm start",
            "request": "launch",
            "type": "node-terminal"
        }
    ]
}